# WeChat Work (企业微信) Configuration
CORP_ID=your_corp_id
CORP_SECRET=your_corp_secret
TOKEN=your_callback_token
ENCODING_AES_KEY=your_encoding_aes_key
AGENT_ID=your_agent_id

# GLM API Configuration
GLM_API_KEY=your_glm_api_key
GLM_API_BASE=https://api.z.ai/api/coding/paas/v4/
GLM_MODEL=glm-4.5-flash

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
DEBUG=false

# Message mode: "kf" for WeChat Customer Service API, "agent" for internal agent messaging
MESSAGE_MODE=kf
KF_OPEN_KFID=your_kf_open_kfid
# KF mode: UserID of the staff member assigned as the bot servicer (接待人员)
KF_SERVICER_USERID=your_servicer_userid
